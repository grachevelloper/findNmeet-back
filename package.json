{
  "name": "findnmeet",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:gateway": "pnpm --filter api-gateway dev",
    "dev:auth": "pnpm --filter auth-service dev",
    "dev:search": "pnpm --filter search-orchestrator dev",
    "dev:favorites": "pnpm --filter favorites-service dev",
    "dev:ai": "pnpm --filter ai-service dev",
    "dev:certs": "sh ./scripts/dev/generate-local-tls.sh",
    "dev:stack": "sh ./scripts/dev/generate-local-tls.sh && docker compose --env-file .env.dev -f docker-compose.dev.yml up --build",
    "dev:stack:down": "docker compose --env-file .env.dev -f docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0"
  }
}
