# Infrastructure
POSTGRES_URL=postgresql://findnmeet:findnmeet@localhost:5432/findnmeet
REDIS_URL=redis://localhost:6379

# VK OAuth
VK_APP_ID=
VK_APP_SECRET=
VK_REDIRECT_URI=https://localhost:3000/api/v1/auth/vk/callback
VK_OAUTH_AUTHORIZE_URL=https://oauth.vk.com/authorize
VK_OAUTH_SCOPE=

# OpenAI
OPENAI_API_KEY=

# JWT (межсервисная авторизация — RSA ключевая пара)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# JWT пользовательские токены
USER_JWT_PRIVATE_KEY=
USER_JWT_PUBLIC_KEY=
USER_JWT_EXPIRES_IN=15m
USER_REFRESH_EXPIRES_IN=30d

# Шифрование VK токенов в БД
TOKEN_ENCRYPTION_KEY=


# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_FRONTEND_URL=http://localhost:5173
API_GATEWAY_CORS_ORIGINS=http://localhost:5173
API_GATEWAY_TLS_KEY_PATH=
API_GATEWAY_TLS_CERT_PATH=
API_GATEWAY_COOKIE_SECURE=false
API_GATEWAY_COOKIE_SAME_SITE=lax
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_GRPC_URL=0.0.0.0:50051
SEARCH_ORCHESTRATOR_PORT=3002
FAVORITES_SERVICE_PORT=3003
AI_SERVICE_PORT=3004
VK_GATEWAY_PORT=8080
VK_GATEWAY_GRPC_URL=0.0.0.0:50054
