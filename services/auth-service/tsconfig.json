{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "jest"],
    "paths": {
      "@findnmeet/ts-types": ["../../packages/ts-types/dist/src"],
      "@findnmeet/ts-types/*": ["../../packages/ts-types/dist/src/*"],
      "@findnmeet/types": ["../../packages/types/dist"],
      "@findnmeet/utils": ["../../packages/utils/dist"],
      "@findnmeet/utils/*": ["../../packages/utils/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
